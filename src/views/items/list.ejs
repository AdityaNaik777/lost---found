<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <title>Lost & Found - All Items</title>
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body>
    <div class="container">
      <%- include('../partials/header') %>

      <h2>All Items</h2>
      <div
        class="stats-container"
        style="display: flex; gap: 20px; margin-bottom: 20px"
      >
        <div class="stat-card">Total: <span id="totalCount">0</span></div>
        <div class="stat-card" style="color: var(--danger)">
          Lost: <span id="lostCount">0</span>
        </div>
        <div class="stat-card" style="color: #10b981">
          Found: <span id="foundCount">0</span>
        </div>
      </div>
      <ul id="itemsList">
        <li>Loading items...</li>
      </ul>
      <%- include('../partials/footer') %>
    </div>

    <script src="/js/main.js"></script>
  </body>
</html>
