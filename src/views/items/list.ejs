<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>LostFound PCCOE</title>
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
      integrity="sha512-SnH5WK+bZxgPHs44uWix+LLJAJ9/2PkPKZ5QiAj6Ta86w+fsb2TkR4Q1L7b9Ica0nPddhY9yyQX6f3fQz0Vd1w=="
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body class="dark-theme">
    <div class="orb orb-a"></div>
    <div class="orb orb-b"></div>
    <div class="container app-shell">
      <%- include('../partials/header') %>

      <section class="hero glass-panel">
        <div>
          <p class="kicker">PCCOE Smart Campus</p>
          <h2>Lost & Found Board</h2>
          <p class="hero-copy">
            Report items quickly and track recovery in one elegant dashboard.
          </p>
        </div>
        <div class="stats-container">
          <div class="stat-card">All Posts <span id="totalCount">0</span></div>
          <div class="stat-card danger">Active Lost <span id="lostCount">0</span></div>
          <div class="stat-card found">Found Reports <span id="foundCount">0</span></div>
          <div class="stat-card success">Resolved <span id="resolvedCount">0</span></div>
        </div>
      </section>

      <section class="section-head">
        <h3>Active Lost Items</h3>
        <button id="openAddItemBtn" class="button gradient-btn">
          <i class="fa-solid fa-plus"></i> Add Item
        </button>
      </section>
      <div id="itemsList" class="items-grid">
        <p>Loading items...</p>
      </div>

      <section id="found" class="section-head">
        <h3>Found Reports</h3>
      </section>
      <div id="foundItemsList" class="items-grid">
        <p>Loading items...</p>
      </div>

      <section id="resolved" class="section-head resolved-head">
        <h3>Resolved Items</h3>
      </section>
      <div id="resolvedItemsList" class="resolved-list glass-panel">
        <p>No resolved items yet.</p>
      </div>

      <div id="itemModal" class="modal hidden">
        <div class="modal-backdrop"></div>
        <div class="modal-content glass-panel">
          <button class="modal-close" id="closeItemModal" aria-label="Close">
            <i class="fa-solid fa-xmark"></i>
          </button>
          <h3>Add New Item</h3>
          <form id="itemForm">
            <div class="form-group">
              <label>Post Type</label>
              <div class="radio-row">
                <label>
                  <input type="radio" name="status" value="lost" checked />
                  <span>I Lost Something</span>
                </label>
                <label>
                  <input type="radio" name="status" value="found" />
                  <span>I Found Something</span>
                </label>
              </div>
            </div>
            <div class="form-group">
              <label for="title">Title</label>
              <input type="text" id="title" name="title" required />
            </div>
            <div class="form-group">
              <label for="description">Details</label>
              <textarea id="description" name="description" rows="4"></textarea>
            </div>
            <div class="form-group">
              <label for="contact">Contact Info</label>
              <input type="text" id="contact" name="contact" required />
            </div>
            <div class="form-group">
              <label for="image">Upload Photo (Optional)</label>
              <input type="file" id="image" name="image" accept="image/*" />
            </div>
            <button type="submit" class="button gradient-btn form-submit">
              Post to Board
            </button>
          </form>
        </div>
      </div>

      <%- include('../partials/footer') %>
    </div>

    <script src="/js/main.js"></script>
  </body>
</html>
